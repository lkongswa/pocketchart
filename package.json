{
  "name": "pocketchart",
  "version": "1.0.0-beta.2",
  "description": "Local-first clinical documentation for solo practitioners",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "webpack serve --mode development",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "deploy": "npm run dist:dir && xcopy /E /Y /I release\\win-unpacked\\* C:\\PocketChart\\ && copy /Y build\\icon.ico C:\\PocketChart\\icon.ico"
  },
  "keywords": [
    "clinical",
    "documentation",
    "therapy",
    "SOAP",
    "notes"
  ],
  "author": "PocketChart",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.pocketchart.app",
    "productName": "PocketChart",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "build/icon.png",
      "node_modules/**/*",
      "!node_modules/**/*.{ts,tsx,map,md}",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "azureSignOptions": {
        "endpoint": "https://wus.codesigning.azure.net/",
        "certificateProfileName": "pocketchart-signing"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PocketChart",
      "include": "build/uninstaller.nsh",
      "uninstallDisplayName": "PocketChart (your data will be kept safe)"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "lkongswa",
        "repo": "pocketchart",
        "private": true
      }
    ]
  },
  "dependencies": {
    "@journeyapps/sqlcipher": "^5.3.1",
    "@types/papaparse": "^5.5.2",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.563.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "stripe": "^20.3.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.3",
    "electron": "^40.1.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  }
}
