{
  "name": "pocketchart",
  "version": "1.3.0",
  "description": "Local-first clinical documentation for solo practitioners",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "webpack serve --mode development",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "deps:setup": "npm rebuild better-sqlite3 @journeyapps/sqlcipher electron electron-winstaller --foreground-scripts --ignore-scripts=false",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "deploy": "npm run dist:dir && xcopy /E /Y /I release\\win-unpacked\\* C:\\PocketChart\\ && copy /Y build\\icon.ico C:\\PocketChart\\icon.ico"
  },
  "keywords": [
    "clinical",
    "documentation",
    "therapy",
    "SOAP",
    "notes"
  ],
  "author": "PocketChart",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.pocketchart.app",
    "productName": "PocketChart",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "build/icon.png",
      "node_modules/**/*",
      "!node_modules/**/*.{ts,tsx,map,md}",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "azureSignOptions": {
        "endpoint": "https://wus.codesigning.azure.net/",
        "codeSigningAccountName": "pocketchart",
        "certificateProfileName": "pocketchart-signing",
        "publisherName": "Lyda Kongswangwongsa"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PocketChart",
      "include": "build/uninstaller.nsh",
      "uninstallDisplayName": "PocketChart (your data will be kept safe)",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "lkongswa",
        "repo": "pocketchart"
      }
    ]
  },
  "dependencies": {
    "@journeyapps/sqlcipher": "5.3.1",
    "@types/papaparse": "^5.5.2",
    "adm-zip": "0.5.17",
    "archiver": "7.0.1",
    "better-sqlite3": "12.10.0",
    "date-fns": "^4.4.0",
    "electron-store": "^11.0.2",
    "electron-updater": "6.8.3",
    "jspdf": "4.2.1",
    "lucide-react": "^0.563.0",
    "nodemailer": "^8.0.10",
    "papaparse": "5.5.3",
    "pdf-lib": "1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "stripe": "20.3.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.4",
    "electron": "40.9.3",
    "electron-builder": "^26.4.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "ts-loader": "^9.6.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "tar": "7.5.13",
    "uuid": "^13.0.0",
    "shell-quote": "^1.8.4",
    "dompurify": "^3.4.8",
    "form-data": "^4.0.6"
  }
}
